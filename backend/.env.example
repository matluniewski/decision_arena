# Generic AI provider configuration used by the app.
APP_AI_MODE=mock
APP_AI_API_KEY=
APP_AI_MODEL=
APP_AI_BASE_URL=

# Optional provider-specific fallbacks kept for compatibility.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# App infrastructure
DATABASE_URL=jdbc:postgresql://localhost:5432/decision_arena
DATABASE_USERNAME=decision_arena
DATABASE_PASSWORD=decision_arena
CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_WINDOW_SECONDS=600
APP_RATE_LIMIT_MAX_REQUESTS=60
